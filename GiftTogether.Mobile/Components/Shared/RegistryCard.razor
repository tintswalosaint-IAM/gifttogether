@namespace GiftTogether.Mobile.Components.Shared

<article class="registry-card @(IsFunded ? "registry-card--funded" : "")"
         @onclick="HandleTap"
         role="button"
         tabindex="0"
         @onkeydown="HandleKeyDown"
         aria-label="@Registry.Name, @((int)FundedPct)% funded">
    <div class="registry-card-thumb" style="@ThumbStyle">
        @if (string.IsNullOrEmpty(Registry.HeroImageUrl))
        {
            <span class="registry-card-initial" aria-hidden="true">
                @(Registry.Name.Length > 0 ? Registry.Name[0].ToString().ToUpper() : "?")
            </span>
        }
        else
        {
            <img src="@Registry.HeroImageUrl" alt="" style="width:100%;height:100%;object-fit:cover;" />
        }
    </div>
    <div class="registry-card-info">
        <div class="registry-card-name">@Registry.Name</div>
        <div class="registry-card-meta">
            @Registry.GiftGoals.Count goal@(Registry.GiftGoals.Count != 1 ? "s" : "")
            · R @TotalRaised.ToString("N0") raised
        </div>
        <ProgressBar Value="@FundedPct" Height="6px" />
        @if (IsFunded)
        {
            <span class="badge badge--success" role="status" style="margin-top: var(--space-2);">
                ✓ Fully funded
            </span>
        }
    </div>
    <svg class="registry-card-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2"
              stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
</article>

@code {
    [Parameter, EditorRequired] public RegistryResponse Registry { get; set; } = default!;
    [Parameter] public EventCallback OnTap { get; set; }

    private decimal TotalRaised => Registry.GiftGoals.Sum(g => g.TotalRaised);
    private decimal TotalTarget => Registry.GiftGoals.Sum(g => g.TargetAmount);
    private decimal FundedPct   => TotalTarget > 0
        ? Math.Min(100, Math.Round(TotalRaised / TotalTarget * 100, 1))
        : 0;
    private bool IsFunded => FundedPct >= 100;

    private string ThumbStyle => string.IsNullOrEmpty(Registry.HeroImageUrl)
        ? $"background: {GetGradient(Registry.Name)};"
        : "";

    private static string GetGradient(string name)
    {
        var hue = Math.Abs(name.GetHashCode()) % 360;
        var hue2 = (hue + 40) % 360;
        return $"linear-gradient(135deg, hsl({hue},70%,60%), hsl({hue2},70%,50%))";
    }

    private Task HandleTap() => OnTap.InvokeAsync();

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || e.Key == " ")
            await OnTap.InvokeAsync();
    }
}
