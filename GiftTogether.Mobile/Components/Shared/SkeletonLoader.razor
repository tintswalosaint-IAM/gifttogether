@namespace GiftTogether.Mobile.Components.Shared

@for (int i = 0; i < Count; i++)
{
    @if (Variant == "registry-card")
    {
        <div class="skeleton--registry-card" aria-hidden="true">
            <div class="skeleton-line skeleton-line--title shimmer"></div>
            <div class="skeleton-line skeleton-line--meta shimmer"></div>
            <div class="skeleton-line skeleton-line--bar shimmer"></div>
        </div>
    }
    else if (Variant == "goal-card")
    {
        <div class="skeleton--goal-card" aria-hidden="true">
            <div class="skeleton-image shimmer"></div>
            <div class="skeleton-body">
                <div class="skeleton-line skeleton-line--title shimmer"></div>
                <div class="skeleton-line skeleton-line--meta shimmer"></div>
                <div class="skeleton-line skeleton-line--bar shimmer"></div>
            </div>
        </div>
    }
    else if (Variant == "hero")
    {
        <div class="hero-section shimmer" aria-hidden="true" style="min-height:220px;"></div>
    }
    else
    {
        <div class="skeleton-line skeleton-line--title shimmer" aria-hidden="true"></div>
    }
}

@code {
    [Parameter] public string Variant { get; set; } = "registry-card";
    [Parameter] public int Count { get; set; } = 3;
}
